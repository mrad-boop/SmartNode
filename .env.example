# ── Copy this file to .env for local development ─────────────
# Never commit .env to git

# PostgreSQL connection string
# Local example:  postgres://postgres:password@localhost:5432/smartnode
# Render injects: automatically via render.yaml
DATABASE_URL=postgres://user:password@localhost:5432/smartnode

# Server
PORT=3000
NODE_ENV=development

# App branding
APP_NAME=SmartNode
APP_TITLE=SmartNode — DeFi Matrix

# Payments (replace with your REAL Solana wallet addresses before going live)
SYSTEM_FEE_ADDRESS=YOUR_SOLANA_WALLET_ADDRESS_HERE
SYSTEM_FEE_AMOUNT=10
LEVEL_AMOUNT=10

# Default matrix usernames (Level 1 → 6)
MATRIX_L1=Admin_Node
MATRIX_L2=System_Link
MATRIX_L3=Global_Alpha
MATRIX_L4=DeFi_Master
MATRIX_L5=Prime_Core
MATRIX_L6=Support_Level

# Wallet address for each default matrix slot (replace with real addresses)
WALLET_L1=YOUR_WALLET_FOR_ADMIN_NODE
WALLET_L2=YOUR_WALLET_FOR_SYSTEM_LINK
WALLET_L3=YOUR_WALLET_FOR_GLOBAL_ALPHA
WALLET_L4=YOUR_WALLET_FOR_DEFI_MASTER
WALLET_L5=YOUR_WALLET_FOR_PRIME_CORE
WALLET_L6=YOUR_WALLET_FOR_SUPPORT_LEVEL
